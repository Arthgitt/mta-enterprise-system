{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/dashboard/(.*)",
      "dest": "/dashboard/$1"
    },
    {
      "src": "/(.*\\.(css|js))",
      "dest": "/dashboard/$1"
    },
    {
      "src": "/(health|employees|payroll|overtime-report|validation-errors|docs|redoc|openapi.json)(.*)",
      "dest": "api/main.py"
    },
    {
      "src": "/",
      "dest": "/dashboard/index.html"
    }
  ]
}
