# ─────────────────────────────────────────────
# MTA Enterprise — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# PostgreSQL (Supabase free tier or local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mta_workforce
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:password@localhost:5432/mta_workforce

# BigQuery (optional — set to enable BQ integration)
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_ID=mta_workforce_analytics
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development     # development | production

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500

# C# Admin Dashboard API Base URL
API_BASE_URL=http://localhost:8000
